<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATH" value="/home/skyrius/habiDue/logs" />
    <property name="LOG_FILE_NAME" value="habidue-app" />

    <!-- 콘솔 출력 설정 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 파일 저장 설정 (Rolling) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 날짜별로 파일명 생성 및 .gz로 압축 보관 -->
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <!-- 개별 파일당 최대 10MB -->
            <maxFileSize>10MB</maxFileSize>
            <!-- 전체 로그 파일 보관 기간 (7일) -->
            <maxHistory>7</maxHistory>
            <!-- 전체 로그 총 용량 제한 (500MB) -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 개발 환경 및 운영 환경에 따른 로그 레벨 설정 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

    <!-- 수집기 로그는 상세하게 보기 위해 DEBUG 설정 (선택 사항) -->
    <logger name="com.habidue.app.service.notice.collector" level="DEBUG" />
</configuration>
